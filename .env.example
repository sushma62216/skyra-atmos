# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=skyra-atmos-data

# Snowflake
SNOWFLAKE_ACCOUNT=your_account_identifier   # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role                    # e.g. ACCOUNTADMIN or a custom role
# Note: warehouse (SKYRA_ATMOS) and database (WEATHER_ANALYTICS) are hardcoded in dbt/weather_analytics profiles.yml

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key

# Environment
ENVIRONMENT=development
